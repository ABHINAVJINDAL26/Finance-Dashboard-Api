              }
            }
          ]
        },
        {
          "name": "❌ Login without Token (Protected Route)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Test accessing protected route without token.\nExpected: 401 Unauthorized"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('No token - 401 Unauthorized', function() {",
                  "  pm.response.to.have.status(401);",
                  "  console.log('✅ Correctly blocked unauthenticated access');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
