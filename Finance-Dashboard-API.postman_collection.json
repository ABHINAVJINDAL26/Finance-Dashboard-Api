              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Register new user. Default role = VIEWER.\nExpected: 201 Created"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
